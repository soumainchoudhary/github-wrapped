# ─── GitHub Wrapped ───────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# (Optional) HuggingFace API token for AI personality summaries.
# If omitted the app falls back to a fun rule-based generator.
HF_API_TOKEN=

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend (Streamlit reads this to locate the API)
API_BASE_URL=http://localhost:8000
